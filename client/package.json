{
  "name": "ety-client",
  "displayName": "ety Language Server",
  "version": "0.0.1",
  "private": true,
  "publisher": "ety",
  "repository": {
    "type": "git",
    "url": "https://github.com/AhnafCodes/ety.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:html",
    "workspaceContains:**/*.{jsp,aspx,tpl,ftl}"
  ],
  "contributes": {
    "configuration": {
      "title": "ety",
      "properties": {
        "ety.scriptHosts": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["html"],
          "markdownDescription": "File extensions whose `<script>` blocks ety analyzes. `.html` works by default; add server-side template formats like `jsp`, `aspx`, `tpl`, `ftl` to enable type-checking of their `<script>` JavaScript. **Reload the window after changing** (the document selector is fixed per session)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "vscode:prepublish": "node esbuild.mjs",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "pretest:e2e": "node esbuild.mjs",
    "test:e2e": "node test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.9"
  }
}
