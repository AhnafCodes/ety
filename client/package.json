{
  "name": "ety-client",
  "displayName": "ety Language Server",
  "version": "0.0.1",
  "private": true,
  "publisher": "ety",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:html",
    "workspaceContains:**/*.{jsp,aspx,tpl,ftl}"
  ],
  "contributes": {
    "configuration": {
      "title": "ety",
      "properties": {
        "ety.scriptHosts": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["html"],
          "markdownDescription": "File extensions whose `<script>` blocks ety analyzes. `.html` works by default; add server-side template formats like `jsp`, `aspx`, `tpl`, `ftl` to enable type-checking of their `<script>` JavaScript. **Reload the window after changing** (the document selector is fixed per session)."
        }
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:e2e": "node test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.3.0",
    "vitest": "^4.1.8"
  }
}
